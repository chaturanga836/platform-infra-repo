# Infra-service environment (local dev / reference)
# Production values live in etl-deployment/.env

INTERNAL_SERVICE_TOKEN=changeme-internal-token
PROVISION_MODE=docker
DATA_PLANE_NETWORK=data-plane-net
INFRA_SERVICE_PORT=9000

# Local / shared Redis for queue broker when PROVISION_MODE=local
# Use compose service hostname (not localhost) so etl-back can reach elt-redis.
LOCAL_REDIS_URL=redis://redis:6379/1
